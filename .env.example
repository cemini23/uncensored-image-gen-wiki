# ============================================================================
# Image Generation Research Workspace — Environment Variables Template
# ============================================================================
# Copy this file to `.env` and fill in your own keys.
# `.env` is gitignored — never commit real keys.
# ============================================================================

# DeepSeek API — for AI-assisted research synthesis (optional)
# Get a key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Brave Search API — for the brave-search MCP server (optional; web search via MCP)
# Get a key at https://api.search.brave.com/
BRAVE_API_KEY=

# Exa API — for the exa MCP server (optional; deep research, GitHub repo crawling)
# Get a key at https://exa.ai/
EXA_API_KEY=

# CivitAI API token — for programmatic model discovery (optional; Playwright works without)
# Get a token at https://civitai.com/user/account
CIVITAI_API_TOKEN=

# Hugging Face token — for gated model downloads (optional)
# Get a token at https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=
